# SQLite database path (on-disk or in-memory for tests)
DATABASE_URL=file:./data/hearth.db

# Reserved (unused — Lucia uses opaque DB session IDs, not signed cookies)
# SESSION_SECRET=

# Server
PORT=3000
NODE_ENV=development

# Web authentication mode: required (default) or open
# required: login gate enforced for the web UI
# open: login gate skipped; web writes attributed to OPEN_MODE_USERNAME.
#       Admin routes still require a logged-in admin. The REST API always
#       requires a bearer token regardless of this setting.
AUTH_MODE=required

# Shared identity used to attribute web writes when AUTH_MODE=open
OPEN_MODE_USERNAME=household

# API tokens (bearer tokens for /api/v1/*) are NOT set here.
# Create and revoke them in Admin -> API tokens (/admin/api-tokens) or via the
# token CLI script. Each token is shown once at creation time.

# Photo and document uploads root (relative to project root)
UPLOADS_DIR=data/uploads

# First admin bootstrap (non-interactive, first deploy only)
HEARTH_BOOTSTRAP_USERNAME=
HEARTH_BOOTSTRAP_PASSWORD=
HEARTH_BOOTSTRAP_DISPLAY_NAME=
